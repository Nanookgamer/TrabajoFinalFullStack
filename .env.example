# Base de datos (desarrollo local)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=JuegoDados
DB_USER=postgres
DB_PASSWORD=tu_password

# Base de datos (producción - Render lo rellena automáticamente)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT (usa una cadena larga y aleatoria)
JWT_SECRET=cambia_esto_por_algo_secreto

# Node (Render lo pone en "production" automáticamente)
NODE_ENV=development
